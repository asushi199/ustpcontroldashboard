# Google Sheet untuk kad OSC (satu spreadsheet, banyak bahagian = lajur `section`)
# Contoh URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit?gid=0
# Kongsi: Sesiapa yang mempunyai pautan boleh melihat (untuk CSV export)
VITE_GOOGLE_SHEET_ID=1rwBiTVkXO0mwe0OUS4EnhAMvsXRDjrplwv6LCphRvTo
# ID tab (gid dalam URL); biasanya 0 untuk tab pertama
VITE_GOOGLE_SHEET_GID=0


# Satu topik OSC = satu tab Sheet sendiri (gid dari URL .../edit?gid=NUM). Kosong = sandaran statik dalam kod.
# Lajur setiap tab (tiada lajur section): subtopik_key, subtopik_title, subtopik_sort, subtopik_blurb, sort, key, title, url, type, blurb
# Templat contoh (salin ke Sheet): public/data/osc-topik-integrasi-demo.csv, osc-topik-hebahan-demo.csv, osc-topik-itm-demo.csv, osc-topik-pembudayaan-membaca-demo.csv, osc-topik-pemerkasaan-demo.csv
# Jika VITE_GOOGLE_SHEET_ID kosong, aplikasi muat CSV demo tersebut untuk pratontak struktur.
VITE_OSC_GID_INTEGRASI=2118454599
VITE_OSC_GID_HEBAHAN=840906136
VITE_OSC_GID_ITM=1783573680
VITE_OSC_GID_PEMBUDAYAAN_MEMBACA=1069849230
VITE_OSC_GID_PEMERKASAAN=1267093369

# Tab tambahan: senarai laman web sekolah (kod, nama, url) — gabung dengan Excel borang; baris sama kod ganti pautan.
# Lajur dibenar: code / KOD SEKOLAH, name / NAMA SEKOLAH, url / PAUTAN / PAUTAN LAMAN WEB…
# Tanpa VITE_GOOGLE_SHEET_ID: muat public/data/laman-web-sekolah-sheet-demo.csv
VITE_OSC_GID_LAMAN_WEB_SEKOLAH=687916087


# Tab berasingan untuk bahagian Analisis Data (OSC). Kosongkan untuk guna fail demo dalam public/data/.
# GID = nombor dalam URL tab Sheet, contoh .../edit?gid=123456789
VITE_ANALISIS_GID_DELIMA=1777239725
VITE_ANALISIS_GID_DCS=950943264
VITE_ANALISIS_GID_AINS=210771871
VITE_ANALISIS_GID_PENSIJILAN=1866678492
VITE_ANALISIS_GID_OPTIK=1586599585

# Tab Maklumat Asas (Carta, PKG, Takwim, jadual pegawai). Kosongkan untuk guna public/data/maklumat-asas-demo.csv
VITE_MAKLUMAT_ASAS_GID=1898676060

# Tab Bahan Sokongan (OSC) — subtopik + kad. Kosongkan = papar sandaran statik dalam kod. Tanpa VITE_GOOGLE_SHEET_ID demo CSV tidak dimuat.
# Lajur: subtopik_key, subtopik_title, subtopik_sort, subtopik_blurb (pilihan), sort, key, title, url, type, blurb
# Jika ada lajur page pada semua baris berisi teks, tapis page=bahan (master sheet).
VITE_BAHAN_SOKONGAN_GID=786977080
