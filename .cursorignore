# Dependencies & build output (large, low value for AI context)
node_modules/
dist/
dist-ssr/
build/
.vite/

# Logs & caches
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.cache/

# Env files (avoid indexing real secrets)
.env
.env.*
!.env.example

# Editor / OS（仅忽略本机向设置；extensions.json / tasks.json 等仍可被索引）
.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local overrides
*.local
